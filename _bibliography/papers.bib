@article{saqib2024education,
  title={The Impact of Terrorism on Education: Evidence from the Death of Osama bin Laden in Pakistan},
  author={Saqib Hussain and Chungeun Yoon},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This paper investigates the impact of terrorism on educational outcomes following the death of Osama bin Laden in Pakistan. The unexpected death of bin Laden, Al-Qaeda's founder and symbolic leader, triggered a significant escalation in retaliatory terrorist attacks. Terrorist groups perceived Pakistan as complicit in the U.S. operation, leading to increased attacks on government, military, and civilian targets, with assaults on educational institutions rising by 50 percent. This surge led to a significant decline in educational attainment, reducing average years of schooling by 0.52 years and lowering primary school completion rates by 5.9 percentage points, with a more pronounced impact on girls. Furthermore, academic performance declined, with math, English, and reading scores falling by approximately 0.1 standard deviations. These findings highlight that the elimination of a terrorist leader can incite retaliatory violence, significantly undermining the educational prospects of children, particularly girls.}
}

@article{saqib2024voting,
  title={The Impact of Terrorism on Voter Turnout: Evidence from Instrumental Variable Estimation},
  author={Saqib Hussain},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This paper investigates the impact of exposure to terrorist attacks on voter turnout in national elections. Given the potential endogeneity in terrorist attack targeting, we construct a set of novel instruments to address this issue. Specifically, we use exogenous variation in the timing and location of major events such as the death of Osama bin Laden and the Red Mosque siege. Using these instruments, we find that terrorist attacks suppress voter turnout by 5 percent and 3 percent more than what is predicted by traditional difference-in-differences estimators. This suggests that terrorist organizations may specifically target areas with positive shocks to enhance their impact on election outcomes. Our findings highlight the role of fear and population migration as key mechanisms driving reduced voter participation, rather than any direct disruption to electoral infrastructure. This study contributes to understanding the broader political and social consequences of terrorism beyond immediate violence.}
}

@article{saqib2024afghanrct,
  title={Improving Displaced Livelihoods: A Training Program for Afghan Refugees in Pakistan},
  author={Saqib Hussain and Sungho Park},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This randomized controlled trial (RCT) evaluates the effectiveness of an intervention aimed at improving the livelihoods of vulnerable Afghan refugee youth in Pakistan by providing them with essential vocational and digital skills. The refugee population faces significant barriers to employment, such as legal restrictions, limited access to basic services like healthcare and education, and a lack of economic opportunities. The intervention addresses these challenges by offering a series of tailored courses that focus on skills in high demand within the local labor market. These courses cover both vocational training and digital literacy, ensuring that the refugees acquire valuable capabilities that can improve their job prospects. Participants are randomly selected and are enrolled in daily training sessions conducted in groups over a three-month period. The intervention design incorporates the strategic use of technology to enhance learning and the involvement of religious leaders to motivate refugees to participate in the program. A follow-up evaluation, conducted three months after the completion of the training, will assess the long-term impacts on the participants' employment outcomes, skills retention, and overall well-being. This evaluation is based on phone surveys, providing important insights into the sustainability and effectiveness of the intervention.}
}

@article{saqib2024lrmisspillover,
  author={Saqib Hussain},
  title={Spillovers of Digitization},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This paper investigates the spillover effects of land record digitization, using high-frequency, incident-level data on corruption, combined with datasets on agricultural credit and land use. The digitization of land records is a key policy reform aimed at improving transparency and reducing corruption within the land administration system. By exploiting the staggered rollout of this program across different regions, the study conducts an intent-to-treat analysis and supplements it with a local average treatment effect (LATE) approach to evaluate the causal impact of digitization on corruption. The results indicate that the availability of transparent, digital land records plays a significant role in reducing corrupt practices, especially by decreasing the discretion of officials in land-related transactions. Furthermore, the analysis highlights that these improvements in transparency are more influential than efforts focused on strengthening the capacity of the state institutions. The findings offer valuable policy implications for other developing countries seeking to reduce corruption and improve governance through the digitization of public services, with broader economic and social benefits stemming from the enhanced accessibility of land-related information.}
}

@article{saqib2024earthquake,
  title={The Long-Term Impact of In-Utero Exposure to Natural Disasters on Human Capital},
  author={Saqib Hussain},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This paper explores the long-term effects of in-utero exposure to natural disasters on human capital outcomes, using the 2005 earthquake in Pakistan as a natural experiment. The earthquake, which struck unexpectedly in the fall of 2005, offers a unique opportunity to test the fetal origins hypothesis, which suggests that prenatal environmental shocks can have lasting effects on individuals' health, education, and income. The study takes advantage of regional and cohort-level variations in exposure to the earthquake, allowing for a comparison between those born just before or after the disaster in different districts. The results show that individuals who were exposed to the earthquake in utero exhibit significantly worse health outcomes, including increased disability rates, as well as lower educational attainment and income levels later in life. These findings underscore the importance of prenatal health interventions and provide strong evidence that in-utero exposure to adverse environmental shocks can have long-lasting, negative effects on human capital development. This research has significant policy implications for improving prenatal care and disaster preparedness, particularly in regions vulnerable to natural disasters.}
}

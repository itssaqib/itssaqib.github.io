@article{saqib2024terroredu,
  title={The Impact of Terrorism on Education: Evidence from the Death of Osama bin Laden in Pakistan},
  author={Saqib Hussain and Chungeun Yoon},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This paper investigates the impact of terrorism on educational outcomes following the death of Osama bin Laden in Pakistan. The unexpected death of bin Laden, Al-Qaeda's founder and symbolic leader, triggered a significant escalation in retaliatory terrorist attacks. Terrorist groups perceived Pakistan as complicit in the U.S. operation, leading to increased attacks on government, military, and civilian targets, with assaults on educational institutions rising by 50 percent. This surge led to a significant decline in educational attainment, reducing average years of schooling by 0.52 years and lowering primary school completion rates by 5.9 percentage points, with a more pronounced impact on girls. Furthermore, academic performance declined, with math, English, and reading scores falling by approximately 0.1 standard deviations. These findings highlight that the elimination of a terrorist leader can incite retaliatory violence, significantly undermining the educational prospects of children, particularly girls.}
}

@article{saqib2024terrorvote,
  title={The Impact of Terrorism on Voter Turnout: Evidence from Instrumental Variable Estimation},
  author={Saqib Hussain},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This paper estimates the effect of exposure to terrorist attacks on election outcomes. Since terrorists may choose targets endogenously, We construct a set of novel instruments. To that end, We leverage exogenous variation of timing and location of the death of Osama bin Laden and the Red Mosque siege. We find that attacks suppress voter turnout by 5 percent and 3 percent more than predicted by . This indicates that terrorists target areas experiencing positive shocks. Evidence suggests fears and migration as mechanisms of impact, rather than electoral infrastructure.}
}

@article{saqib2024afghanrct,
  title={Improving Displaced Livelihoods: A Training Program for Afghan Refugees in Pakistan},
  author={Saqib Hussain and Sungho Park},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This randomized controlled trial evaluates an intervention that aims to equip the vulnerable youth of Afghan refugees in Pakistan with vocational and digital skills in the labor market. The primary objective of the intervention is to bypass the source problem of legal issues of refugees, who lack access to health, education, and decent job opportunities. The research aims to develop tailored courses focusing on in-demand vocational and digital skills and randomly deliver them to the recruited refugees. The treatment will be given on a daily basis in groups for a period of three months. This project seeks to leverage the cruciality of technology in the present era to motivate and inspire Afghan refugees to enroll in the training, with the instrumental involvement of religious leaders. Besides an endline evaluation of 3 months post-treatment completion, we will be examining the effects of the training after 3 months of the completion of training via phone surveys.  }
}

@article{saqib2024lrmisspillover,
  author={Saqib Hussain},
  title={Spillovers of Digitization},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={I use high-frequency, incident-level confidential corruption data, combined with agricultural credit and land use datasets, to estimate the impact of land record digitization. Exploiting the program’s staggered rollout, I conduct an intent-to-treat analysis, supplemented by a local average treatment effect approach. The primary mechanism driving the association appears to be the availability of transparent information rather than state capacity-building efforts. }
}

@article{saqib2024earthquake,
  title={The Long-Term Impact of In-Utero Exposure to Natural Disasters on Human Capital},
  author={Saqib Hussain},
  journal={},
  volume={},
  number={},
  pages={},
  year={2024},
  publisher={},
  selected={false},
  abbr={},
  abstract={This paper uses the 2005 earthquake as a natural experiment for testing the fetal origins hypothesis. The earthquake happened unexpectedly in the fall of 2005, generating sharp predictions for long‐term effects. I exploit the variation across the birth cohorts and districts exposed to this event. I find that cohorts in utero during the earthquake displayed increased disabilities and reduced educational attainment and income. These results indicate the importance of investing in fetal health to enhance human capital outcomes. }
}
